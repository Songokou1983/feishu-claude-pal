# Feishu-Claude Bridge v2 Configuration
# Copy to config.env in the project root and edit

# Default working directory for Claude Code sessions
CTI_DEFAULT_WORKDIR=/path/to/your/project

# Default model (optional — inherits from CLI default if not set)
# CTI_DEFAULT_MODEL=

# Default mode (code, plan, ask)
CTI_DEFAULT_MODE=code

# ── Claude CLI path (optional) ──
# Override if the daemon picks the wrong `claude` binary.
# CTI_CLAUDE_CODE_EXECUTABLE=/path/to/claude

# ── Third-party API provider (optional) ──
# MiniMax (兼容 Claude Sonnet 4)
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your-minimax-key
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
# MINIMAX_AUTH_TOKEN=your-minimax-key

# ── 火山引擎 Ark (GLM) ──
# Base URL 必须是 https://ark.cn-beijing.volces.com/api/coding（不是 /api/coding/v1）
# 支持模型: glm-5.1, glm-4.7, doubao-seed-2.0-code, minimax-latest 等
# GLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
# GLM_API_KEY=your-ark-api-key

# ── 模型选项 ──
# 可用模型: minimax / glm-5.1
# 通过 /model 命令切换，或设置 CTI_DEFAULT_MODEL 为默认模型
# CTI_DEFAULT_MODEL=glm-5.1

# ── Feishu / Lark ──
CTI_FEISHU_APP_ID=your-app-id
CTI_FEISHU_APP_SECRET=your-app-secret
# Domain: feishu (default) or lark
CTI_FEISHU_DOMAIN=feishu
# Restrict access to specific user/chat IDs (comma-separated, empty = allow all)
# CTI_FEISHU_ALLOWED_USERS=user_id_1,user_id_2
# Require @mention in group chats (default: true)
CTI_FEISHU_REQUIRE_MENTION=true

# ── Permission ──
# Auto-approve all tool permission requests without user confirmation.
# ⚠️  Only enable this in trusted, access-controlled environments.
# CTI_AUTO_APPROVE=true
